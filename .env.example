# Copy to .env and fill in. Never commit .env.

# Required for Discord alerts (omit to only print + log locally).
DISCORD_WEBHOOK_URL=

# Optional overrides
# SIGHTMAP_URL=https://sightmap.com/app/api/v1/jlw075ogv2y/sightmaps/83961
# DB_PATH=sightmap.db
# LOG_PATH=changes.log

# If true, Discord only when the diff is non-empty (inventory still in terminal + changes.log).
# DISCORD_ONLY_ON_CHANGES=false
